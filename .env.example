# Tatakai - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Web Configuration (Vite)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_BACKEND_ORIGIN=https://api.your-domain.com
VITE_ADMIN_API_SECRET=must_match_tatakaiapi_admin_secret
VITE_TATAKAI_API_URL=https://api.tatakai.me:4000/api/v1
VITE_HIANIME_API_URL=https://api.tatakai.me/api/v2/hianime
VITE_MANGA_API_URL=https://core.tatakai.me/api/v2/manga
VITE_LOCAL_HIANIME_ORIGIN=https://api.tatakai.me

# MyAnimeList Integration
VITE_MAL_CLIENT_ID=your_mal_client_id
VITE_MAL_REDIRECT_URI=your_mal_redirect_uri
VITE_MAL_AUTH_FUNCTION_URL=your_supabase_function_url_for_mal_auth

# AniList Integration
VITE_ANILIST_CLIENT_ID=your_anilist_client_id
VITE_ANILIST_REDIRECT_URI=your_anilist_redirect_uri

# Proxy Loader (Node)
# Comma-separated proxy URLs, first entry should be the primary node proxy.
VITE_PROXY_POOL_URLS=https://hoko.tatakai.me/api/v1/streamingProxy
VITE_PROXY_CF_URL=
VITE_PROXY_NODE_URL=https://hoko.tatakai.me/api/v1/streamingProxy
VITE_PROXY_BUN_URL=

# Streaming Proxy (Node)
# Example URL: https://proxy.your-domain.com/api/v1/streamingProxy
VITE_STREAM_PROXY_URL=https://hoko.tatakai.me/api/v1/streamingProxy
VITE_STREAM_PROXY_PASSWORD=your-shared-proxy-password

# Mobile Configuration (Flutter)
API_BASE_URL=your_api_base_url
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
DATABASE_URL=your_database_url
PROXY_URL=your_proxy_url
WATCHANIMEWORLD_SCRAPER_URL=your_scraper_url

# Analytics
VITE_GA_MEASUREMENT_ID=your_google_analytics_id
VITE_DD_SITE=datadoghq.com
VITE_DD_CLIENT_TOKEN=your_datadog_client_token

# Extractor Service (Local Development)
VITE_EXTRACTOR_SERVICE_URL=https://api.tatakai.me:3001

# Discord Community Page (/discord)
# Enable widget in Discord: Server Settings → Widget → Enable Server Widget
VITE_DISCORD_GUILD_ID=1465759865539526973
VITE_DISCORD_INVITE=https://discord.gg/tatakai

# Discord Activity (embedded app in voice channels)
# Application ID from Discord Developer Portal with Activities enabled
VITE_DISCORD_CLIENT_ID=your_discord_activity_app_id

# Backend Discord Webhooks (TatakaiAPI)
DISCORD_WEBHOOK_STATUS=

# Pretty API logs in local development
TATAKAI_LOG_PRETTY=true

# API Encryption Secret (must match TatakaiAPI's API_SECRET)
# Leave empty to disable request signing
VITE_API_SECRET=

# 